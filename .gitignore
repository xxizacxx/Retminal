# ===================================================================
#   .gitignore de Retminal
#   (par xxizacxx)
# ===================================================================

# ------------------------------------------------------------------
#  SECRETS — NE JAMAIS PUBLIER  (mots de passe, tokens, IP du VPS)
# ------------------------------------------------------------------
.env
*.env
secret.env
!*.env.example
context.md

# ------------------------------------------------------------------
#  Python
# ------------------------------------------------------------------
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/

# ------------------------------------------------------------------
#  Environnements virtuels
# ------------------------------------------------------------------
.venv/
venv/
env/
.venv-build/

# ------------------------------------------------------------------
#  PyInstaller (le .exe se refabrique avec build.bat)
# ------------------------------------------------------------------
build/
dist/
*.spec

# ------------------------------------------------------------------
#  Version Mac (l'appli + le .dmg se fabriquent sur le Mac)
# ------------------------------------------------------------------
Version-Mac/build/
Version-Mac/dist/
Version-Mac/.venv-build/
*.app/
*.dmg
dmg-stage/

# ------------------------------------------------------------------
#  Données perso (images collées dans Claude, parfois lourdes)
# ------------------------------------------------------------------
images_collees/

# ------------------------------------------------------------------
#  Node (les petits sites)
# ------------------------------------------------------------------
node_modules/
site_avancement/go.*

# ------------------------------------------------------------------
#  Fichiers de test temporaires
# ------------------------------------------------------------------
_cctest.py
_test*.py
_shot*.py

# ------------------------------------------------------------------
#  Éditeurs / IDE
# ------------------------------------------------------------------
.vscode/
.idea/
*.swp
*~

# ------------------------------------------------------------------
#  Système d'exploitation
# ------------------------------------------------------------------
.DS_Store
Thumbs.db
desktop.ini
